{
  "expo": {
    "name": "Comanda",
    "slug": "comanda",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "comanda",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A0F0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ktuche.comanda"
    },
    "android": {
      "package": "com.ktuche.comanda",
      "backgroundColor": "#1A0F0A",
      "adaptiveIcon": {
        "backgroundColor": "#1A0F0A"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
